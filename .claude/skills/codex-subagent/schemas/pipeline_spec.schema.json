{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["stages"],
  "$defs": {
    "stage_spec": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "planner",
            "executor",
            "reviewer",
            "verifier",
            "releaser",
            "reducer"
          ]
        },
        "sandbox": {
          "type": "string",
          "enum": [
            "read-only",
            "workspace-write",
            "danger-full-access"
          ]
        },
        "workdir": {
          "type": "string",
          "minLength": 1
        },
        "write_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "input_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "merge_strategy": {
          "type": "string",
          "enum": [
            "concat",
            "dedup",
            "priority",
            "consensus"
          ]
        },
        "prompt": {
          "type": "string"
        },
        "instructions": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["2.0"]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage_spec"
      }
    },
    "allow_dynamic_stages": {
      "type": "boolean"
    },
    "allowed_stage_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "max_total_prompt_chars": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
